# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Build directories
/build/
/cmake-build-*/
/out/

# CMake FetchContent cache
_deps/

# Large user-provided scenes dropped into assets (keep repo lean; sample assets are tracked explicitly)
/assets/scenes/*
!/assets/scenes/.gitkeep
!/assets/scenes/*.glb

# Exported renders
*.render.png
